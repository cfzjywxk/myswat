%% MySwat Workflow Decision & Drive Graph
%% Generated from engine.py, review_loop.py, work_cmd.py

flowchart TD
    START(["`**User: myswat work**
    requirement`"]) --> CANCEL_CHECK_0{Cancelled?}
    CANCEL_CHECK_0 -->|Yes| ABORT_EARLY([Abort])
    CANCEL_CHECK_0 -->|No| S1

    subgraph S1["Stage 1: Technical Design"]
        DEV_DESIGN["`**Dev** produces
        technical design`"]
        DEV_DESIGN --> DESIGN_OK{Dev success?}
        DESIGN_OK -->|No| ABORT1([Abort workflow])
    end

    DESIGN_OK -->|Yes| CANCEL_CHECK_1{Cancelled?}
    CANCEL_CHECK_1 -->|Yes| ABORT([Abort])
    CANCEL_CHECK_1 -->|No| S2

    subgraph S2["Stage 2: Design Review Loop"]
        DR_START["`Iteration 1..max_review`"]
        DR_START --> DR_PERSIST_ARTIFACT[Store artifact in DB]
        DR_PERSIST_ARTIFACT --> DR_QA_REVIEW

        DR_QA_REVIEW["`**Each QA** reviews design`"]
        DR_QA_REVIEW --> DR_ALL_LGTM{All reviewers LGTM?}

        DR_ALL_LGTM -->|Yes| DR_APPROVED([Design Approved])
        DR_ALL_LGTM -->|No| DR_MAX{Max iterations?}
        DR_MAX -->|Yes| DR_TIMEOUT([Max iters reached])
        DR_MAX -->|No| DR_DEV_REVISE["`**Dev** addresses
        review comments`"]
        DR_DEV_REVISE --> DR_REVISE_OK{Dev success?}
        DR_REVISE_OK -->|No| DR_TIMEOUT
        DR_REVISE_OK -->|Yes| DR_START
    end

    DR_APPROVED --> USER_CP_DESIGN
    DR_TIMEOUT --> USER_CP_DESIGN

    USER_CP_DESIGN{"`**User Checkpoint**
    Proceed / feedback / stop?`"}
    USER_CP_DESIGN -->|auto_approve or Y| S3
    USER_CP_DESIGN -->|N| STOP_USER([User stopped workflow])
    USER_CP_DESIGN -->|feedback text| DEV_ADDR_DESIGN["`**Dev** addresses
    user feedback`"] --> USER_CP_DESIGN

    subgraph S3["Stage 3: Implementation Planning"]
        DEV_PLAN["`**Dev** creates
        implementation plan`"]
        DEV_PLAN --> PLAN_OK{Dev success?}
        PLAN_OK -->|No| ABORT3([Abort workflow])
    end

    PLAN_OK -->|Yes| CANCEL_CHECK_3{Cancelled?}
    CANCEL_CHECK_3 -->|Yes| ABORT([Abort])
    CANCEL_CHECK_3 -->|No| S4

    subgraph S4["Stage 4: Plan Review Loop"]
        PR_START["`Iteration 1..max_review`"]
        PR_START --> PR_QA_REVIEW["`**Each QA** reviews plan`"]
        PR_QA_REVIEW --> PR_ALL_LGTM{All reviewers LGTM?}

        PR_ALL_LGTM -->|Yes| PR_APPROVED([Plan Approved])
        PR_ALL_LGTM -->|No| PR_MAX{Max iterations?}
        PR_MAX -->|Yes| PR_TIMEOUT([Max iters reached])
        PR_MAX -->|No| PR_DEV_REVISE["`**Dev** addresses
        plan comments`"]
        PR_DEV_REVISE --> PR_START
    end

    PR_APPROVED --> USER_CP_PLAN
    PR_TIMEOUT --> USER_CP_PLAN

    USER_CP_PLAN{"`**User Checkpoint**
    Start development?`"}
    USER_CP_PLAN -->|auto_approve or Y| S5
    USER_CP_PLAN -->|N| STOP_USER2([User stopped workflow])
    USER_CP_PLAN -->|feedback text| DEV_ADDR_PLAN["`**Dev** addresses
    user feedback`"] --> USER_CP_PLAN

    subgraph S5["Stage 5: Phased Development"]
        PARSE_PHASES[Parse phases from plan]
        PARSE_PHASES --> PHASE_LOOP

        subgraph PHASE_LOOP["For each phase i/N"]
            P_CANCEL{Cancelled?}
            P_CANCEL -->|Yes| P_ABORT([Skip remaining])
            P_CANCEL -->|No| P_IMPLEMENT

            P_IMPLEMENT["`**Dev** implements
            phase i`"]
            P_IMPLEMENT --> P_IMPL_OK{Dev success?}
            P_IMPL_OK -->|No| P_FAIL([Phase failed])
            P_IMPL_OK -->|Yes| P_SUMMARIZE["`**Dev** summarizes
            changes`"]

            P_SUMMARIZE --> P_CODE_REVIEW

            subgraph P_CODE_REVIEW["Code Review Loop"]
                CR_QA["`**Each QA** reviews code`"]
                CR_QA --> CR_LGTM{All LGTM?}
                CR_LGTM -->|Yes| CR_PASS([Code Approved])
                CR_LGTM -->|No| CR_MAX{Max iters?}
                CR_MAX -->|Yes| CR_TIMEOUT([Max iters])
                CR_MAX -->|No| CR_DEV_FIX["`**Dev** addresses
                code comments`"]
                CR_DEV_FIX --> CR_QA
            end

            CR_PASS --> P_COMMIT
            CR_TIMEOUT --> P_COMMIT
            P_COMMIT["`**Dev** commits
            phase i`"]
            P_COMMIT --> P_COMMITTED{Commit OK?}
            P_COMMITTED -->|Yes| P_DONE([Phase done])
            P_COMMITTED -->|No| P_COMMIT_FAIL([Commit failed])
        end

        P_DONE --> NEXT_PHASE{More phases?}
        P_FAIL --> NEXT_PHASE
        P_COMMIT_FAIL --> NEXT_PHASE
        NEXT_PHASE -->|Yes| PHASE_LOOP
        NEXT_PHASE -->|No| PHASES_DONE([All phases done])
    end

    PHASES_DONE --> S6

    subgraph S6["Stage 6: GA Test"]
        GA_PLAN["`**QA lead** generates
        GA test plan`"]
        GA_PLAN --> GA_PLAN_OK{QA success?}
        GA_PLAN_OK -->|No| GA_ABORT([GA incomplete])

        GA_PLAN_OK -->|Yes| GA_PLAN_REVIEW

        subgraph GA_PLAN_REVIEW["Test Plan Review Loop"]
            direction TB
            TPR_DEV["`**Dev** reviews
            test plan`"]
            TPR_DEV --> TPR_LGTM{LGTM?}
            TPR_LGTM -->|Yes| TPR_PASS([Test plan approved])
            TPR_LGTM -->|No| TPR_MAX{Max iters?}
            TPR_MAX -->|Yes| TPR_TIMEOUT([Max iters])
            TPR_MAX -->|No| TPR_QA_FIX["`**QA** addresses
            comments`"]
            TPR_QA_FIX --> TPR_DEV
        end

        TPR_PASS --> USER_CP_TEST
        TPR_TIMEOUT --> USER_CP_TEST

        USER_CP_TEST{"`**User Checkpoint**
        Approve test plan?`"}
        USER_CP_TEST -->|N| GA_ABORT2([GA aborted])
        USER_CP_TEST -->|auto_approve or Y| GA_EXECUTE
        USER_CP_TEST -->|feedback| QA_ADDR_TEST["`**QA** addresses
        user feedback`"] --> USER_CP_TEST

        GA_EXECUTE["`**QA lead** executes
        GA tests`"]
        GA_EXECUTE --> GA_EXEC_OK{QA success?}
        GA_EXEC_OK -->|No| GA_ABORT

        GA_EXEC_OK -->|Yes| PARSE_BUGS[Parse test results]
        PARSE_BUGS --> BUGS_FOUND{Bugs found?}
        BUGS_FOUND -->|No| GA_PASSED([All tests passed])

        BUGS_FOUND -->|Yes| BUG_FIX_LOOP

        subgraph BUG_FIX_LOOP["Bug Fix Loop"]
            BF_TOO_MANY{"`Total bugs
            > MAX_GA_BUGS 5?`"}
            BF_TOO_MANY -->|Yes| BF_ABORT([GA aborted: too many bugs])

            BF_TOO_MANY -->|No| BF_EACH_BUG

            subgraph BF_EACH_BUG["For each bug"]
                BF_ESTIMATE["`**Dev** estimates bug`"]
                BF_ESTIMATE --> BF_TYPE{Assessment?}

                BF_TYPE -->|simple_fix| BF_SIMPLE["`**Dev** fixes bug`"]
                BF_SIMPLE --> BF_SUMMARIZE["`**Dev** summarizes fix`"]

                BF_TYPE -->|arch_change| BF_ARCH

                subgraph BF_ARCH["Sub-Workflow: Architecture Bug Fix"]
                    direction TB
                    BFA_DESIGN["`**Dev** redesigns`"]
                    BFA_DESIGN --> BFA_REVIEW["`Design review loop`"]
                    BFA_REVIEW --> BFA_USER_CP["`User checkpoint`"]
                    BFA_USER_CP --> BFA_PLAN["`**Dev** replans`"]
                    BFA_PLAN --> BFA_PLAN_REVIEW["`Plan review loop`"]
                    BFA_PLAN_REVIEW --> BFA_USER_CP2["`User checkpoint`"]
                    BFA_USER_CP2 --> BFA_DEV["`Phased dev
                    implement, review, commit`"]
                end
            end

            BF_SUMMARIZE --> BF_NEXT{More bugs?}
            BF_ARCH --> BF_NEXT
            BF_NEXT -->|Yes| BF_EACH_BUG
            BF_NEXT -->|No| BF_RETEST

            BF_RETEST["`**QA lead** re-runs
            tests after fixes`"]
            BF_RETEST --> BF_REPARSE[Parse results]
            BF_REPARSE --> BF_NEW_BUGS{New bugs?}
            BF_NEW_BUGS -->|Yes| BF_TOO_MANY
            BF_NEW_BUGS -->|No| BF_ALL_PASS([All pass after fixes])
        end

        BF_ALL_PASS --> GA_REPORT
        BF_ABORT --> GA_REPORT
        GA_PASSED --> GA_REPORT_SKIP

        GA_REPORT["`**QA lead** generates
        test report`"]
        GA_REPORT_SKIP["`Skip detailed report`"]
    end

    GA_REPORT --> S7
    GA_REPORT_SKIP --> S7
    GA_ABORT --> S7
    GA_ABORT2 --> S7

    subgraph S7["Stage 7: Final Report"]
        DEV_REPORT["`**Dev** writes
        final narrative report`"]
        DEV_REPORT --> BUILD_REPORT["`**MySwat** builds
        structured E2E report`"]
        BUILD_REPORT --> SUCCESS_CHECK{"`All phases committed
        AND GA passed?`"}
        SUCCESS_CHECK -->|Yes| WF_SUCCESS([workflow_completed])
        SUCCESS_CHECK -->|No| WF_ISSUES([workflow_finished_with_issues])
    end

    WF_SUCCESS --> FINAL_STATUS
    WF_ISSUES --> FINAL_STATUS
    FINAL_STATUS["`Update work item status
    Close all sessions`"]

    style START fill:#e1f5fe
    style WF_SUCCESS fill:#c8e6c9
    style WF_ISSUES fill:#fff9c4
    style ABORT fill:#ffcdd2
    style ABORT1 fill:#ffcdd2
    style ABORT3 fill:#ffcdd2
    style ABORT_EARLY fill:#ffcdd2
    style STOP_USER fill:#ffcdd2
    style STOP_USER2 fill:#ffcdd2
    style BF_ABORT fill:#ffcdd2
    style GA_ABORT fill:#ffcdd2
    style GA_ABORT2 fill:#ffcdd2
